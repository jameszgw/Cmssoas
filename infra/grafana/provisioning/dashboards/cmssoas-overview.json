{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "CMSSOAS 概览",
  "tags": ["cmssoas"],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP 请求速率 (req/s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"cmssoas\"}[1m])) by (uri)", "legendFormat": "{{uri}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP P95 延迟 (s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"cmssoas\"}[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM 堆内存使用 (bytes)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{application=\"cmssoas\",area=\"heap\"})", "legendFormat": "heap used" }
      ]
    },
    {
      "type": "stat",
      "title": "进程运行时长 (s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "process_uptime_seconds{application=\"cmssoas\"}", "legendFormat": "uptime" }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  }
}
