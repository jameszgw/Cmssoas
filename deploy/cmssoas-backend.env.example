# /etc/cmssoas/backend.env —— 复制为 backend.env 并按环境填写
# profile：prod 走 PostgreSQL；如用 Nacos 则 nacos,prod 且需 -Pnacos 构建
SPRING_PROFILES_ACTIVE=prod

# 数据库（PostgreSQL）
DB_URL=jdbc:postgresql://127.0.0.1:5432/cmssoas
DB_USER=cmssoas
DB_PASSWORD=please-change

# Redis（nonce/席位）
APP_REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT 签发密钥（务必更换为足够长的随机串）
JWT_SECRET=please-change-to-a-long-random-secret-string-0123456789

# 签名算法：ed25519 | sm2（国密）
LICENSE_SIGN_ALGO=ed25519

# 邮件：log（落盘）| smtp（真实外发）
APP_MAIL_DELIVERY=smtp
MAIL_HOST=smtp.example.com
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=please-change
APP_MAIL_FROM=no-reply@example.com
APP_ACTIVATION_BASE_URL=https://console.example.com/activate

# CORS（前端域名；前后端同源经 nginx 反代时可留空）
CORS_ORIGINS=https://console.example.com

# Nacos（仅 profile 含 nacos 时）
# NACOS_ADDR=127.0.0.1:8848
# NACOS_NAMESPACE=prod
# NACOS_GROUP=DEFAULT_GROUP
# NACOS_DATA_ID=cmssoas.yml
