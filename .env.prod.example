# CMSSOAS 生产环境变量模板
# 用法:cp .env.prod.example .env 并填入真实值;docker compose 自动读取 .env。
# 生产请务必修改:JWT_SECRET、数据库口令、SMTP、CORS、密钥渠道。.env 含密钥,切勿入库。

# ===== 安全(必改) =====
JWT_SECRET=__请替换为足够长的随机字符串__
LICENSE_SIGN_ALGO=ed25519            # ed25519 | sm2(国密)

# ===== 数据库(生产:PostgreSQL,推荐) =====
# 默认 compose 内置 postgres;如用外置库,改 compose backend 的 DB_URL/DB_USER/DB_PASSWORD,
# 或在自建部署(systemd)中通过下列变量注入:
# DB_URL=jdbc:postgresql://db-host:5432/cmssoas
# DB_USER=cmssoas
# DB_PASSWORD=__强口令__
# Redis(nonce 后端,多实例必备)
APP_REDIS_ENABLED=true
# REDIS_HOST=redis
# REDIS_PORT=6379

# ===== 邮件(生产用 SMTP) =====
APP_MAIL_DELIVERY=smtp
MAIL_HOST=smtp.example.com
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=__邮箱授权码__
APP_MAIL_FROM=no-reply@example.com
APP_ACTIVATION_BASE_URL=https://console.example.com/activate

# ===== 访问控制 / 前端来源 =====
CORS_ORIGINS=https://console.example.com

# ===== 告警(可选) =====
ALERT_WECOM_WEBHOOK=

# ===== 支付 / 发票渠道 =====
PAY_PROVIDER=mock                     # mock(人工确认到账) | wechatpay | alipay | stripe
PAY_NOTIFY_BASE_URL=https://api.example.com   # 真实支付渠道异步回调可达的公网根地址
EINVOICE_PROVIDER=mock                # mock(沙箱) | aisino | baiwang

# ===== 智能客服大模型(生产建议:云 API 最省 或 本地 Ollama 合规) =====
AI_ENABLED=true
# 云 API(可出网,最省):智谱 GLM-4-Flash(常免费)
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_API_KEY=__你的key__
AI_MODEL=glm-4-flash
# 合规/内网:改为本地 Ollama
# AI_BASE_URL=http://ollama:11434/v1
# AI_API_KEY=
# AI_MODEL=qwen2.5:7b-instruct
