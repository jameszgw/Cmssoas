# CODEMAN 环境变量模板
# 用法:cp .env.example .env 并按需修改;docker compose 会自动读取 .env。
# 仅含需要自定义的项;数据库/Redis 已在 docker-compose 内置(如需改见 compose)。
# 注意:.env 含密钥,切勿提交到仓库(已建议在 .gitignore 忽略)。

# ===== 安全(生产必改) =====
JWT_SECRET=please-change-this-to-a-long-random-secret-string
LICENSE_SIGN_ALGO=ed25519            # ed25519(默认) | sm2(国密)

# ===== 邮件(发件箱)。默认 log 仅落盘;配 SMTP 后改 smtp =====
APP_MAIL_DELIVERY=log                 # log | smtp
MAIL_HOST=
MAIL_USERNAME=
MAIL_PASSWORD=
APP_MAIL_FROM=no-reply@codeman.com
APP_ACTIVATION_BASE_URL=http://localhost/activate

# ===== 告警(可选) =====
ALERT_WECOM_WEBHOOK=                  # 企业微信群机器人地址,留空禁用

# ===== 支付 / 发票渠道(默认沙箱/人工,可出网后改真实渠道) =====
PAY_PROVIDER=mock                     # mock(人工确认到账) | wechatpay | alipay | stripe
EINVOICE_PROVIDER=mock                # mock(沙箱) | aisino(航信) | baiwang(百望)

# ===== 智能客服大模型(通用 OpenAI 兼容,三选一) =====
# 默认关闭:AI_ENABLED=false 时客服窗仍可用,回复走“知识库降级”。
AI_ENABLED=false
#
# —— 方案①:本地 Ollama(离线/合规,先 `docker compose --profile ai up -d` 并拉模型)——
AI_BASE_URL=http://ollama:11434/v1
AI_API_KEY=
AI_MODEL=qwen2.5:7b-instruct
#
# —— 方案②:智谱 GLM-4-Flash(常有免费额度,最省) ——
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# AI_API_KEY=你的key
# AI_MODEL=glm-4-flash
#
# —— 方案③:通义 qwen-turbo(极低价) ——
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_API_KEY=你的key
# AI_MODEL=qwen-turbo
#
# —— 方案④:DeepSeek-V3 ——
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_API_KEY=你的key
# AI_MODEL=deepseek-chat
#
# 高级(可选):AI_TIMEOUT_SEC=60   AI_HISTORY_LIMIT=12

# ===== 在线代码加固(上传 jar→加固→下载) =====
HARDEN_WORK_DIR=./var/harden
HARDEN_MAX_FILE_MB=200
